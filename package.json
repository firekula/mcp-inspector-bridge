{
	"name": "mcp-inspector-bridge",
	"version": "0.0.1",
	"description": "Modern Cocos Inspector Bridge using TypeScript and Vue 3",
	"author": "Firekula",
	"main": "dist/main.js",
	"scripts": {
		"build": "tsc",
		"watch": "tsc -w"
	},
	"main-menu": {
